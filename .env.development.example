# Local development environment variables.
# Copy this file to .env.development and fill in values from `terraform output`
# in infrastructure/environments/dev after running terraform apply.
#
# This file is safe to commit. .env.development is gitignored.

VITE_API_URL=https://api.seating-chart.yourdomain.com/v1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your_cognito_client_id
VITE_COGNITO_DOMAIN=https://auth-seating-chart-dev.auth.us-east-1.amazoncognito.com
VITE_REDIRECT_URI=http://localhost:5173/auth/callback
